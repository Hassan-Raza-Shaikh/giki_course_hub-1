# Flask Configuration
SECRET_KEY=your_super_secret_key_here
ALLOWED_ORIGINS=http://localhost:5173

# Database Configuration (PostgreSQL)
DB_HOST=your_db_host
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=5432

# Firebase Configuration
# Path to your service account JSON file (e.g., firebase/serviceAccountKey.json)
FIREBASE_CREDENTIALS=firebase/serviceAccountKey.json
FIREBASE_BUCKET=your-project.appspot.com

# Cloudflare R2 / S3 Storage Configuration
R2_BUCKET=your_bucket_name
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_PUBLIC_URL_PREFIX=https://pub-your-id.r2.dev
