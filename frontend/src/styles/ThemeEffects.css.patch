+/* MINECRAFT CUBES */
+.minecraft-block {
+  transform-style: preserve-3d;
+  animation: blockRotate 10s infinite linear, fall linear infinite;
+}
+.cube-face {
+  position: absolute; width: 100%; height: 100%; background: #8d6e63; border: 2px solid #5d4037;
+}
+.cube-face.front  { transform: translateZ(10px); }
+.cube-face.back   { transform: rotateY(180deg) translateZ(10px); }
+.cube-face.right  { transform: rotateY(90deg) translateZ(10px); }
+.cube-face.left   { transform: rotateY(-90deg) translateZ(10px); }
+.cube-face.top    { transform: rotateX(90deg) translateZ(10px); background: #4caf50; border: 2px solid #388e3c; }
+.cube-face.bottom { transform: rotateX(-90deg) translateZ(10px); }
+@keyframes blockRotate {
+  0% { transform: translateY(-100px) rotateX(0) rotateY(0) rotateZ(0); }
+  100% { transform: translateY(110vh) rotateX(360deg) rotateY(360deg) rotateZ(360deg); }
+}
